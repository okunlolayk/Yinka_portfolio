---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { ProjectProps } from "@types";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

<Section text="Featured Projects" href="projects" eyebrow="Projects" tone="paper-alt">
  {
    projects.map(({ name, summary, image, linkPreview, linkSource }, index) => {
      const top = 90 + index * 32;
      return (
        <div style={`top: ${top}px;`} class="sticky mb-10 border border-black/15 bg-paper-alt">
          <div class="grid grid-rows-2 sm:grid-cols-[0.85fr_1.15fr] sm:grid-rows-1">
            {/* cover — left side, per brand spec */}
            <div class="relative order-1 flex min-h-[220px] items-center justify-center overflow-hidden bg-ink md:h-96">
              <Image
                class="h-full w-full object-cover object-top opacity-90"
                src={image}
                alt={name}
                width="640"
                height="480"
              />
              <span class="absolute bottom-4 left-4 h-8 w-8 rounded-full border border-signal/40 bg-signal/15">
                <span class="absolute inset-[9px] rounded-full bg-signal" />
              </span>
            </div>

            {/* body — right side */}
            <div class="order-2 flex flex-col justify-center px-6 py-8 sm:px-8 md:h-96">
              <span class="wiki-tag mb-3 font-mono text-xs text-pen uppercase">Case Study</span>
              <h3 class="mb-4 font-serif text-2xl font-semibold text-ink md:text-3xl">{name}</h3>
              <p class="max-w-md text-[15px] leading-relaxed text-ink-soft">{summary}</p>
              <div class="mt-8 flex gap-6 font-mono text-[13px]">
                <a
                  href={linkSource}
                  target="_blank"
                  class="border-b border-black/20 pb-0.5 text-ink transition-colors hover:border-pen hover:text-pen"
                >
                  Source →
                </a>
                <a
                  href={linkPreview}
                  target="_blank"
                  class="border-b border-black/20 pb-0.5 text-ink transition-colors hover:border-pen hover:text-pen"
                >
                  Preview →
                </a>
              </div>
            </div>
          </div>
        </div>
      );
    })
  }
</Section>
