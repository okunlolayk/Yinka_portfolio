---
import Section from "./Section.astro";
import type { ExperienceProps } from "@types";

interface Props {
  experience: ExperienceProps[];
}

const { experience } = Astro.props;
---

<Section text="Work Experience" href="experience" eyebrow="Experience" tone="paper">
  <div class="flex flex-col divide-y divide-black/10 border-t border-black/10">
    {
      experience.map(({ company, position, startDate, endDate, summary }) => (
        <div class="py-8 first:pt-0">
          <h3 class="mb-1 font-serif text-2xl font-semibold text-ink">{company}</h3>
          <div class="mb-4 flex flex-wrap items-baseline gap-3">
            <h4 class="font-serif text-xl font-medium text-pen italic">{position}</h4>
            <span class="font-mono text-[12.5px] text-ink-soft">
              {startDate} — {endDate}
            </span>
          </div>
          {Array.isArray(summary) ? (
            <ul class="list-none space-y-3">
              {summary.map((log) => (
                <li class="relative pl-6 text-[15px] leading-relaxed text-ink-soft before:absolute before:top-2 before:left-0 before:h-1.5 before:w-1.5 before:rounded-full before:bg-signal before:content-['']">
                  {log}
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-[15px] leading-relaxed text-ink-soft">{summary}</p>
          )}
        </div>
      ))
    }
  </div>
</Section>
