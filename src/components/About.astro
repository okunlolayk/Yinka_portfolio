---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { AboutProps, HeroProps } from "@types";

type Props = AboutProps & Pick<HeroProps, "name">;

const { description, image, name } = Astro.props;
---

<Section text="About Me" href="about" eyebrow="About" tone="paper">
  <div class="flex flex-col items-center gap-12 md:flex-row md:items-start md:gap-10">
    <p class="max-w-xl text-[15.5px] leading-[1.75] whitespace-pre-line text-ink-soft">
      {description}
    </p>
    <div class="w-64 flex-shrink-0 rotate-[5deg] border border-black/15 bg-paper-alt p-3 md:rotate-[6deg]">
      <Image class="h-64 w-full object-cover" src={image} width="260" height="260" alt={name} />
      <span class="mt-2 block text-center font-mono text-[11px] text-ink-soft">{name}</span>
    </div>
  </div>
</Section>
